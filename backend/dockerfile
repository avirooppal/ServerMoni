# ─── Stage 1: Build ───────────────────────────────────────────────────────────
FROM golang:1.24-alpine AS build

# Install git for any go module that needs it
RUN apk add --no-cache git

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Build a static Linux binary (CGO off for scratch/alpine compat)
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
    go build -ldflags="-s -w" -o api ./cmd/api

# ─── Stage 2: Runtime ─────────────────────────────────────────────────────────
FROM alpine:3.19

# ca-certificates needed for any outbound HTTPS calls (geo-IP etc.)
RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

COPY --from=build /app/api .

# Runtime env (overridden by docker-compose or ENV inject at deploy time)
ENV PORT=5001
ENV CORS_ORIGIN=*

EXPOSE 5001

ENTRYPOINT ["./api"]
